@page "/activity-log"
@using Shared.Dtos
@using Web.Services
@inject INodeService _nodeService;
@inject IActivityLogsService _logsService;


<PageTitle>Activity Log</PageTitle>

<MudPaper Class="p-5" Elevation="0" Style="background-color: transparent;">
    <MudText Typo="Typo.h5">Activity Log</MudText>
    <MudDivider Class="my-2" Style="border-color: transparent;" />

    <MudStack Row="true" Justify="Justify.FlexStart" AlignItems="AlignItems.Start">
        <MudCard Class="p-3 rounded-4" Style="min-width: 250px;" Elevation="0" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudPaper Elevation="0" Style="background-color: transparent">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Large" />
                </MudPaper>
                <MudPaper Elevation="0" Style="background-color: transparent">
                    <MudText Typo="Typo.h6">@SuccessCount</MudText>
                    <MudText Class="fw-light" Style="color: gray;">Successful</MudText>
                </MudPaper>
            </MudStack>
        </MudCard>
        <MudCard Class="p-3 rounded-4" Style="min-width: 250px;" Elevation="0" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudPaper Elevation="0" Style="background-color: transparent">
                    <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" Color="Color.Warning" Size="Size.Large" />
                </MudPaper>
                <MudPaper Elevation="0" Style="background-color: transparent">
                    <MudText Typo="Typo.h6">@WarningCount</MudText>
                    <MudText Class="fw-light" Style="color: gray;">Warnings</MudText>
                </MudPaper>
            </MudStack>
        </MudCard>
        <MudCard Class="p-3 rounded-4" Style="min-width: 250px;" Elevation="0" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudPaper Elevation="0" Style="background-color: transparent">
                    <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Color="Color.Error" Size="Size.Large" />
                </MudPaper>
                <MudPaper Elevation="0" Style="background-color: transparent">
                    <MudText Typo="Typo.h6">@ErrorCount</MudText>
                    <MudText Class="fw-light" Style="color: gray;">Errors</MudText>
                </MudPaper>
            </MudStack>
        </MudCard>
    </MudStack>
    <MudDivider Class="my-3" Style="border-color: transparent;" />


    <MudTable Class="rounded-4" Items="@_activityLogs" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Start Time</MudTh>
            <MudTh>End Time</MudTh>
            <MudTh>Action</MudTh>
            <MudTh>User</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nr">@context.StartTime</MudTd>
            <MudTd DataLabel="Sign">@context.EndTime</MudTd>
            <MudTd DataLabel="Name">@context.Action</MudTd>
            <MudTd DataLabel="User">@context.User</MudTd>
            <MudTd DataLabel="Status">
                @if (context.Status is null)
                {
                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">Unknown</MudChip>
                }
                else if (context.Status.ToLower().Equals("ok"))
                {
                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">Ok</MudChip>
                }
                else
                {
                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">@context.Status.ToUpper()</MudChip>
                }
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

</MudPaper>

@code {
    private int SuccessCount => _activityLogs.Where(l => l.Status!.ToLower() == "ok").Count();
    private int WarningCount => _activityLogs.Where(l => l.Status!.ToLower() != "ok").Count();
    private int ErrorCount => _activityLogs.Where(l => l.Status is null).Count();

    private List<ActivityLogDto> _activityLogs = new();

    // TODO: Implement proper exception handling
    protected override async Task OnInitializedAsync()
    {
        try {
        var nodeName = await _nodeService.GetSelectedNodeNameAsync();
        _activityLogs = await _logsService.GetActivityLogsAsync(nodeName);
        } catch (Exception ex) {
            Console.WriteLine(ex.Message);
        }
    }

}