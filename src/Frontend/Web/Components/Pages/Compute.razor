    private bool FilterFunc1(Resource resource) => FilterFunc(resource, searchString);
    private bool FilterFunc(Resource resource, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (resource.type.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (resource.name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (resource.ipAddress.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{resource.type} {resource.name} {resource.ipAddress}".Contains(searchString))
            return true;
        return false;
    }

