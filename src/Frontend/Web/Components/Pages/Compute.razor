@page "/compute"
@using System.ComponentModel.DataAnnotations

<PageTitle>Compute</PageTitle>

<MudPaper Class="p-5" Elevation="0" Style="background-color: transparent;">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudItem>
            <MudText Typo="Typo.h5">Compute Resources</MudText>
        </MudItem>
        <MudItem>
            <MudChipSet T="Color">
                <MudChip T="string" Color="Color.Info">7 Running</MudChip>
                <MudChip T="string" Color="Color.Surface">2 Stopped</MudChip>
            </MudChipSet>
        </MudItem>

    </MudStack>

    <MudDivider Class="my-1" Style="border-color: transparent;" />

    <MudStack Row="false">
        <MudItem>
            <MudTextField @bind-Value="searchString" Placeholder="Search by name, type, or IP address..."
                          Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start"
                          Immediate="true">
            </MudTextField>
        </MudItem>
        <MudItem>
            <MudTable Class="rounded-4" Items="@resources" Breakpoint="Breakpoint.SmAndDown" Loading="@_loading"
                      LoadingProgressColor="Color.Info" Filter="new Func<Resource,bool>(FilterFunc1)">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>IP Address</MudTh>
                    <MudTh>CPU</MudTh>
                    <MudTh>Memory</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.id</MudTd>
                    <MudTd>
                        @if (context.type.Equals("VM"))
                        {
                            <MudChip T="string" Label="true" Color="Color.Primary" Variant="Variant.Outlined"
                                     Size="Size.Small">VM</MudChip>
                        }
                        else if (context.type.Equals("LXC"))
                        {
                            <MudChip T="string" Label="true" Color="Color.Info" Variant="Variant.Outlined"
                                     Size="Size.Small">LXC</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.name</MudTd>
                    <MudTd>
                        @if (context.status)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">running</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">stopped</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.ipAddress</MudTd>
                    <MudTd>@context.cpuCores</MudTd>
                    <MudTd>@context.memory MB</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudItem>
    </MudStack>


</MudPaper>

