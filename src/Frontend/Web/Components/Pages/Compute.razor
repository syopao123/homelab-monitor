@page "/compute"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Shared.Dtos
@using Web.Services
@inject IResourcesService _resourceService;
@inject INodeService _nodeService;

<PageTitle>Compute</PageTitle>

<MudPaper Class="p-5" Elevation="0" Style="background-color: transparent;">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudItem>
            <MudText Typo="Typo.h5">Compute Resources</MudText>
        </MudItem>
        <MudItem>
            <MudChipSet T="Color">
                <MudChip T="string" Color="Color.Info">@(RunningCount) Running</MudChip>
                <MudChip T="string" Color="Color.Surface">@(StoppedCount) Stopped</MudChip>
            </MudChipSet>
        </MudItem>

    </MudStack>

    <MudDivider Class="my-1" Style="border-color: transparent;" />

    <MudStack Row="false">
        <MudItem>
            <MudTextField @bind-Value="searchString" Placeholder="Search by name, type, or IP address..."
                          Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start"
                          Immediate="true">
            </MudTextField>
        </MudItem>
        <MudItem>
            <MudTable Class="rounded-4" Items="@resources" Breakpoint="Breakpoint.SmAndDown" Loading="@_loading"
                      LoadingProgressColor="Color.Info" Filter="new Func<WorkloadDto,bool>(FilterFunc1)">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>IP Address</MudTh>
                    <MudTh>CPU</MudTh>
                    <MudTh>Memory</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Vmid</MudTd>
                    <MudTd>
                        @if (context.Type!.Equals("VM"))
                        {
                            <MudChip T="string" Label="true" Color="Color.Primary" Variant="Variant.Filled"
                                     Size="Size.Small">VM</MudChip>
                        }
                        else if (context.Type.Equals("LXC"))
                        {
                            <MudChip T="string" Label="true" Color="Color.Info" Variant="Variant.Filled"
                                     Size="Size.Small">LXC</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>
                        @if (string.IsNullOrEmpty(context.Status))
                        {
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small">Unknown</MudChip>
                        }
                        else if (context.Status.Equals("running"))
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">running</MudChip>
                        }
                        else if (context.Status.Equals("stopped"))
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">stopped</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.IpAddress</MudTd>
                    <MudTd>@context.CpuCores</MudTd>
                    <MudTd>@(context.MemoryMax/(1024 * 1024)) MB</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudItem>
    </MudStack>


</MudPaper>

@code {
    private string searchString = "";
    private bool _loading;
    private string ActiveNodeName { get; set; } = "";
    private List<WorkloadDto> resources = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        ActiveNodeName = await _nodeService.GetSelectedNodeNameAsync();
        resources = await _resourceService.GetResourcesAsync(ActiveNodeName);
        _loading = false;
    }

    private int RunningCount => resources.Where(r => r.Status == "running").Count();
    private int StoppedCount => resources.Where(r => r.Status == "stopped").Count();


    private bool FilterFunc1(WorkloadDto resource) => FilterFunc(resource, searchString);
    private bool FilterFunc(WorkloadDto resource, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (resource.Type!.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (resource.Name!.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (resource.IpAddress!.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{resource.Type} {resource.Name} {resource.IpAddress}".Contains(searchString))
            return true;
        return false;
    }

}