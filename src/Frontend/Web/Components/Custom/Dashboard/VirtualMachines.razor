<MudCard Class="pb-2 rounded-3" Elevation="0" Outlined="true">
    <MudCardContent>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">Virtual Machines</MudText>
        </MudStack>

        <MudDivider Class="my-2" Style="border-color: transparent;" />

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h4">@Total</MudText>
            <MudText Typo="Typo.h5" Color="Color.Success">@Running</MudText>
        </MudStack>

        <MudDivider Class="my-1" Style="border-color: transparent;" />

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.subtitle1" Style="@($"color:{Colors.Gray.Darken1}")">Total VMs</MudText>
            <MudText Typo="Typo.subtitle1" Style="@($"color:{Colors.Gray.Darken1}")">Running</MudText>
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public required int Total { get; set; }
    [Parameter]
    public required int Running { get; set; }
}