<MudCard Class="p-2 rounded-3" Elevation="0" Outlined="true">
    <MudCardContent>

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6" Style="@($"color:{Color.Dark}")">Node Information</MudText>
        </MudStack>

        <MudDivider Class="my-3" Style="border-color: transparent;" />

        <MudGrid Justify="Justify.SpaceBetween">

            <MudItem Style="min-width: 50%;">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body1" Style="color: rgb(94, 94, 94);">Node Name</MudText>
                    <MudText Typo="Typo.body1">@NodeName</MudText>
                </MudStack>
                <MudDivider Class="my-2" Style="border-color: gray;" />
            </MudItem>

            <MudItem Style="min-width: 50%;">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body1" Style="color: rgb(94, 94, 94);">PVE Version</MudText>
                    <MudText Typo="Typo.body1">@PveVersion</MudText>
                </MudStack>
                <MudDivider Class="my-2" Style="border-color: gray;" />
            </MudItem>

            <MudItem Style="min-width: 50%;">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body1" Style="color: rgb(94, 94, 94);">Kernel Version</MudText>
                    <MudText Typo="Typo.body1">@KernelVersion</MudText>
                </MudStack>
                <MudDivider Class="my-2" Style="border-color: gray;" />
            </MudItem>

            <MudItem Style="min-width: 50%;">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body1" Style="color: rgb(94, 94, 94);">Uptime</MudText>
                    <MudText Typo="Typo.body1">@Uptime</MudText>
                </MudStack>
                <MudDivider Class="my-2" Style="border-color: gray;" />
            </MudItem>

        </MudGrid>

    </MudCardContent>
</MudCard>

@code {
    [Parameter] public required string NodeName { get; set; }
    [Parameter] public required string PveVersion { get; set; }
    [Parameter] public required string KernelVersion { get; set; }
    [Parameter] public required string Uptime { get; set; }
}