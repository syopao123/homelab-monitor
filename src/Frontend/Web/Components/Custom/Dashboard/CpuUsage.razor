<MudCard Style="width: 250px;" Class="pb-2 rounded-3" Elevation="0" Outlined="true">
    <MudCardContent>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">CPU Usage</MudText>
            <MudIcon Icon="@cpuIcon" Title="CPU" Size="Size.Medium" Color="Color.Primary" />
        </MudStack>
        <MudDivider Class="my-3" Style="border-color: transparent;" />
        <MudText Typo="Typo.h5">25%</MudText>
        <MudProgressLinear Color="Color.Primary" Rounded="true" Size="Size.Small" Value="25" />
    </MudCardContent>
    <MudCardActions>
        @* <MudButton Variant="Variant.Text" Color="Color.Primary">Learn more</MudButton> *@
    </MudCardActions>
</MudCard>

