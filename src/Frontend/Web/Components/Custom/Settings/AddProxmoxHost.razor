@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using Shared.Dtos
@using Web.Services
@inject IHostService _hostService;

<MudDialog Class="rounded-3">
    <TitleContent>
        <MudText Typo="Typo.h6">Add Proxmox Host</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@hostDto" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <MudTextField T="string" Label="Host Name" @bind-Value="hostDto.HostName" For="@(() => hostDto.HostName)"
                          Placeholder="e.g., Main Server, Backup Server" />
                        
            <MudDivider Class="py-2" Style="border-color: transparent;" />

            <MudTextField T="string" Label="Server URL" @bind-Value="hostDto.ServerUrl" For="@(() => hostDto.ServerUrl)"
                          Placeholder="https://10.10.0.1:8006/" />

            <MudDivider Class="py-2" Style="border-color: transparent;" />

            <MudTextField T="string" Label="API Token" @bind-Value="hostDto.ApiToken" For="@(() => hostDto.ApiToken)"
                          Placeholder="PVEAPIToken=user@pam!token=. . ."
                          HelperText="Generate an API token in Proxmox VE under Datacenter > Permissions > API Tokens"
                          InputType="InputType.Text" MaxLines="10" />

            <MudDivider Class="py-2" Style="border-color: transparent;" />

            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton OnClick="Cancel">Cancel</MudButton>
                <MudButton Color="Color.Primary" ButtonType="ButtonType.Submit">Add Host</MudButton>
            </MudStack>

            <MudDivider Class="py-2" Style="border-color: transparent;" />
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private CreateHostDto hostDto = new();

    private async Task OnValidSubmit()
    {
        await _hostService.RegisterHostAsync(hostDto);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
