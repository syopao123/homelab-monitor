@using Shared.Dtos.Storage
<MudGrid>
    @foreach (var storage in Pool)
    {
        var usedPercentage = Math.Round((double) storage.Used / storage.Total * 100, 2);

        <MudItem>
            <MudCard Class="p-4 pt-4 rounded-4" Style="min-width: 500px;" Elevation="0" Outlined="true">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudItem>
                        <MudText Typo="Typo.h6">@storage.Storage</MudText>
                    </MudItem>
                    <MudItem>
                        <MudText Color="Color.Success">@usedPercentage %
                        </MudText>
                    </MudItem>
                </MudStack>
                <MudText Typo="Typo.subtitle1" Class="fw-light" Style="color: gray;">
                    @(storage.Type is not null ? char.ToUpper(storage.Type[0]) + storage.Type.Substring(1) : "Unknown Type")
                </MudText>
                <MudDivider Class="my-1" Style="border-color: transparent;" />

                <MudProgressLinear Color="Color.Primary" Size="Size.Medium" Value="@usedPercentage" />
                <MudDivider Class="my-2" Style="border-color: transparent;" />

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudPaper Elevation="0">
                        <MudText Typo="Typo.body2" Style="color: gray;">Total</MudText>
                        <MudText Typo="Typo.subtitle1">@(storage.Total / (1024 * 1024 * 1024)) GB</MudText>
                    </MudPaper>
                    <MudPaper Elevation="0">
                        <MudText Typo="Typo.body2" Style="color: gray;">Used</MudText>
                        <MudText Typo="Typo.subtitle1">@(storage.Used / (1024 * 1024 * 1024)) GB</MudText>
                    </MudPaper>
                    <MudPaper Elevation="0">
                        <MudText Typo="Typo.body2" Style="color: gray;">Available</MudText>
                        <MudText Typo="Typo.subtitle1">@(storage.Available / (1024 * 1024 * 1024)) GB</MudText>
                    </MudPaper>
                </MudStack>
                <MudDivider Class="my-2" Style="border-color: transparent;" />

                <MudText Typo="Typo.subtitle1" Class="fw-light" Style="color: gray;">Content Types</MudText>
                <MudGrid Justify="Justify.FlexStart">
                    <MudItem>
                        @if (storage.ContentTypes is not null && storage.ContentTypes.Count() > 0)
                        {
                            @foreach (var contentType in storage.ContentTypes)
                            {
                                <MudChip T="string" Size="Size.Small">@contentType</MudChip>
                            }
                        }
                    </MudItem>
                </MudGrid>

            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter]
    public List<StorageDto> Pool { get; set; } = new();
}