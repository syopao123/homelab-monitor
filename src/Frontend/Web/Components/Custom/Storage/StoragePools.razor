<MudGrid>
    @foreach (var storagePool in storagePools)
    {
        var usedPercentage = storagePool.usedCapacity / storagePool.totalCapacity * 100;

        <MudItem>
            <MudCard Class="p-4 pt-4 rounded-4" Style="min-width: 500px;" Elevation="0" Outlined="true">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudItem>
                        <MudText Typo="Typo.h6">@storagePool.name</MudText>
                    </MudItem>
                    <MudItem>
                        <MudText Color="Color.Success">@usedPercentage %
                        </MudText>
                    </MudItem>
                </MudStack>
                <MudText Typo="Typo.subtitle1" Class="fw-light" Style="color: gray;">
                    @(char.ToUpper(storagePool.type[0]) + storagePool.type.Substring(1))
                </MudText>
                <MudDivider Class="my-1" Style="border-color: transparent;" />

                <MudProgressLinear Color="Color.Primary" Size="Size.Medium" Value="@usedPercentage" />
                <MudDivider Class="my-2" Style="border-color: transparent;" />

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudPaper Elevation="0">
                        <MudText Typo="Typo.body2" Style="color: gray;">Total</MudText>
                        <MudText Typo="Typo.subtitle1">@storagePool.totalCapacity GB</MudText>
                    </MudPaper>
                    <MudPaper Elevation="0">
                        <MudText Typo="Typo.body2" Style="color: gray;">Used</MudText>
                        <MudText Typo="Typo.subtitle1">@storagePool.usedCapacity GB</MudText>
                    </MudPaper>
                    <MudPaper Elevation="0">
                        <MudText Typo="Typo.body2" Style="color: gray;">Available</MudText>
                        <MudText Typo="Typo.subtitle1">@storagePool.availableCapacity GB</MudText>
                    </MudPaper>
                </MudStack>
                <MudDivider Class="my-2" Style="border-color: transparent;" />

                <MudText Typo="Typo.subtitle1" Class="fw-light" Style="color: gray;">Content Types</MudText>
                <MudGrid Justify="Justify.FlexStart">
                    <MudItem>
                    @foreach (var contentType in storagePool.contentTypes)
                    {
                        <MudChip T="string" Size="Size.Small">@contentType</MudChip>
                    }
                    </MudItem>
                </MudGrid>

            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    @* Temporary Data *@
    public class StoragePool
    {
        public string name { get; set; } = "";
        public string type { get; set; } = "";
        public double totalCapacity { get; set; }
        public double usedCapacity { get; set; }
        public double availableCapacity { get; set; }
        public List<string> contentTypes { get; set; } = new();
    }

    public List<StoragePool> storagePools = new List<StoragePool> {
        new StoragePool {
            name = "local",
            type = "directory",
            totalCapacity = 500,
            usedCapacity = 350,
            availableCapacity = 150,
            contentTypes = new List<string> { "images", "rootdir" }
        },

        new StoragePool {
            name = "local-lvm",
            type = "LVM-Thin",
            totalCapacity = 1000,
            usedCapacity = 720,
            availableCapacity = 280,
            contentTypes = new List<string> { "images" }
        },

        new StoragePool {
            name = "zfs-pool",
            type = "ZFS",
            totalCapacity = 2000,
            usedCapacity = 1400,
            availableCapacity = 600,
            contentTypes = new List<string> { "images", "rootdir", "backup" }
        },

        new StoragePool {
            name = "nfs-storage",
            type = "NFS",
            totalCapacity = 5000,
            usedCapacity = 3200,
            availableCapacity = 1800,
            contentTypes = new List<string> { "backup", "iso" }
        }
    };
}