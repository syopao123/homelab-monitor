<MudCard Class="p-4 pt-5 rounded-4" Outlined="true" Elevation="0">
    <MudText Typo="Typo.h6">Storage Overview</MudText>
    <MudDivider Class="py-3" Style="border-color: transparent;" />
    <MudGrid Justify="Justify.SpaceEvenly">
        <MudItem>
            <MudStack Row="false" Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1" Style="color: gray;">Total Capacity</MudText>
                <MudText Typo="Typo.h5">@TotalCapacity GB</MudText>
            </MudStack>
        </MudItem>
        <MudItem>
            <MudStack Row="false" Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1" Style="color: gray;">Total Used</MudText>
                <MudText Typo="Typo.h5">@TotalUsed GB</MudText>
            </MudStack>
        </MudItem>
        <MudItem>
            <MudStack Row="false" Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1" Style="color: gray;">Total Available</MudText>
                <MudText Typo="Typo.h5">@TotalAvailable GB</MudText>
            </MudStack>
        </MudItem>
        <MudItem>
            <MudStack Row="false" Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1" Style="color: gray;">Storage Pools</MudText>
                <MudText Typo="Typo.h5">@StorageCount</MudText>
            </MudStack>
        </MudItem>
    </MudGrid>
    <MudDivider Class="py-1" Style="border-color: transparent;" />
</MudCard>

@code {
    [Parameter] public double TotalCapacity { get; set; }
    [Parameter] public double TotalUsed { get; set; }
    [Parameter] public double TotalAvailable { get; set; }
    [Parameter] public int StorageCount { get; set; }
}